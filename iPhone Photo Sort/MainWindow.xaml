<Window x:Class="iPhone_Photo_Sort.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:iPhone_Photo_Sort"
        mc:Ignorable="d"
        Title="iPhone Photo Sort" Height="169" Width="480">
  <Grid Background="#FF3C3939">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="68*"/>
      <ColumnDefinition Width="413*"/>
    </Grid.ColumnDefinitions>
    <Button x:Name="FolderButton" Content="Button" HorizontalAlignment="Left" Margin="18,49,0,0" VerticalAlignment="Top" Click="button_Click" Grid.Column="1"/>
    <Label x:Name="label" Grid.Column="1" Content="Label" HorizontalAlignment="Left" Margin="71,46,0,0" VerticalAlignment="Top" Background="White" Width="284"/>
  </Grid>
</Window>
